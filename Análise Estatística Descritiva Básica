import statistics as st
n = int(input("Qual a quantidade de números que você vai informar? "))

dados = []

for i in range(n):
  num = float(input(f'Digite {i+1}º número: '))
  dados.append(num)

print('A média dos números informados é', st.mean(dados))
print('A mediana dos números é:', st.median(dados))
